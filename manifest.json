{
  "manifest_version": 3,
  "name": "Pure Start",
  "version": "2.0.0",
  "description": "纯净、简洁的浏览器起始页 — 轻量、流畅、现代。",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.bing.com/*",
    "https://v1.hitokoto.cn/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src *"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
