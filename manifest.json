{
  "manifest_version": 3,
  "name": "Pure Start",
  "version": "1.1.0",
  "description": "纯净、简洁的浏览器起始页 — 轻量、流畅、现代。",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.bing.com/*",
    "https://v1.hitokoto.cn/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
